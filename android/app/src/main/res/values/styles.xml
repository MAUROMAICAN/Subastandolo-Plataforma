<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — DARK everywhere -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#161625</item>
        <item name="colorPrimaryDark">#161625</item>
        <item name="colorAccent">#c8f135</item>
        <item name="android:windowBackground">#161625</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#161625</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#161625</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#161625</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <!-- Launch theme — same dark bg, NO SplashScreen dependency -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <item name="android:background">#161625</item>
    </style>
</resources>